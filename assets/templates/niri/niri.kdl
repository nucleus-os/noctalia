layout {

    focus-ring {
        active-color   "{{colors.primary.default.hex}}"
        inactive-color "{{colors.surface.default.hex}}"
        urgent-color   "{{colors.error.default.hex}}"
    }

    border {
        active-color   "{{colors.primary.default.hex}}"
        inactive-color "{{colors.surface.default.hex}}"
        urgent-color   "{{colors.error.default.hex}}"
    }

    shadow {
        color "{{colors.shadow.default.hex}}70"
    }

    tab-indicator {
        active-color   "{{colors.primary.default.hex}}"
        inactive-color "{{colors.primary_container.default.hex}}"
        urgent-color   "{{colors.error.default.hex}}"
    }

    insert-hint {
        color "{{colors.primary.default.hex}}80"
    }
}

recent-windows {
    highlight {
        active-color "{{colors.primary.default.hex}}"
        urgent-color "{{colors.error.default.hex}}"
    }
}

// noctalia's CEF-backed panels (Apple Music, Discord, ...) open as real xdg_toplevel windows
// under a shared nonce'd app-id prefix so this one rule covers all of them. `shell-surface`
// bundles open-floating + always-on-top + no compositor open/close animation (noctalia's own
// panels use a native shell-reveal shader instead) + switcher exclusion, matching how these
// panels behaved back when they were layer-shell surfaces.
window-rule {
    match app-id=r#"^dev\.noctalia\.panel-open-"#
    shell-surface true
}
